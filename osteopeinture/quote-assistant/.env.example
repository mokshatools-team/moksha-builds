# Anthropic API key — get yours at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Email (Gmail recommended — use an App Password, not your regular password)
# To generate App Password: Google Account → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@osteopeinture.com
SMTP_PASS=your-gmail-app-password

# Optional Gmail scrape accounts for past-quotes/scrape-gmail.js
# Primary defaults to SMTP_USER / SMTP_PASS if these are omitted.
GMAIL_SCRAPE_PRIMARY_USER=
GMAIL_SCRAPE_PRIMARY_PASS=
GMAIL_SCRAPE_SECONDARY_USER=
GMAIL_SCRAPE_SECONDARY_PASS=

# Server port (Railway sets this automatically)
PORT=3000

# Persistent storage directory (set to /data on Railway with a Volume)
# Leave blank for local dev — will use ./data/
DATA_DIR=
