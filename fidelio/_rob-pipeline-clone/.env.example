# Fidelio Pipeline — Environment Variables
# Copy to .env and fill in values before running

# ── AI APIs ──
OPENAI_API_KEY=sk-...           # Whisper transcription
ANTHROPIC_API_KEY=sk-ant-...    # Claude metadata generation
FAL_KEY=...                     # FAL.ai thumbnail generation

# ── Google Sheets ──
# Service account JSON — either path to file or inline JSON string
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

# ── Social Posting ──
BLOTATO_API_KEY=...             # Blotato REST API key (Dre's account — Robert sends this)
PUBLER_API_KEY=...              # Publer fallback (optional)

# ── Dropbox ──
DROPBOX_ACCESS_TOKEN=...        # Dropbox app token for client review video hosting (Robert sends this)

# ── App ──
FLASK_SECRET_KEY=change-me-to-a-random-string
PORT=5400                       # Local status UI port

# ── Paths ──
FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
CACHE_DIR=~/.fidelio/cache
THUMBNAIL_DIR=~/.fidelio/thumbnails
